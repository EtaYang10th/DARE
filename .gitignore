# ============================================================
# Anonymization / double-blind release safety
# ============================================================
# Never publish local git metadata; it contains author names, emails, remotes,
# reflogs, and timestamps. This is mainly for manual archive workflows.
.git/

# Public release should not include ad hoc root launchers. They frequently
# contain local environment setup, absolute paths, or machine-specific notes.
/*.sh

# Root-level RL launchers are easy to contaminate with personal paths,
# cluster accounts, W&B URLs, and local environment names. Keep only the
# sanitized anonymous example launcher.
rl_training/*.sh
!rl_training/run_anonymous_example.sh

# Personal launchers, cluster schedulers, and ad hoc job scripts.
rl_training/run_bash/
*.slurm
*.sbatch
*.pbs
*.qsub
*.lsf
*.job
*.submit
slurm-*.out
logs/
**/logs/

# W&B local metadata often stores usernames, hostnames, project URLs,
# entity names, and absolute paths.
wandb/
**/wandb/
.wandb/
**/.wandb/
**/wandb-metadata.json
**/wandb-summary.json
**/wandb-history.jsonl
**/latest-run/
wandb-secret*
*wandb_reader*.sh

# Hydra/Ray runtime outputs often store absolute working directories and
# full command-line overrides.
**/.hydra/
.multirun/
**/multirun/
ray_results/
**/ray_results/

# Local/private machine-specific files that often include usernames, hostnames,
# absolute paths, tokens, or site-specific cluster settings.
.local/
**/.local/
local/
**/local/
private/
**/private/
scratch/
**/scratch/
tmp/
**/tmp/
temp/
**/temp/
*.local
*.local.*
*_local.*
*.private
*.private.*
*_private.*
*.secret
*.token
*.tmp
*.bak
*.orig

# Interactive notebooks and packaged archives may contain executed outputs,
# absolute paths, usernames, or hidden metadata.
*.ipynb
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# Profiler, TensorBoard, and tracing outputs can capture host and path metadata.
*.prof
*.trace
profile/
**/profile/
profiles/
**/profiles/
runs/
**/runs/
events.out.tfevents.*

# Known personal or accidental local files from pre-anonymous runs.
environment.sh
rl_training/ondemand_run_mcts.slurm
rl_training/openondemand_run_mcts.slurm
rl_training/wandb_reader.sh
rl_training/run_bash/common_ds_teacher_replay_config.sh
adaptive_difficulty_prediction/data-efficient-llm-rl/

